                {s.trend}
              </div>
            </div>
            <div style={{ width: 50, height: 50, borderRadius: 14, background: s.bg, display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
              <span className="material-symbols-outlined" style={{ fontSize: 26, color: s.ic }}>{s.icon}</span>
            </div>
