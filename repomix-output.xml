  { icon:'two_wheeler', ibc:'#fef2f2', ic:'#ef4444', title:'Thanh toán thất bại - Khu C', desc:'59B1-123.45 · 4h 00 phút', time:'06/04, 09:00', amount:'5,000 VNĐ', status: 'Lỗi', ac:'#ef4444' },
]

export default function BKPay() {
