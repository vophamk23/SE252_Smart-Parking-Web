<file path="src/index.css">
@tailwind base;
@tailwind components;
@tailwind utilities;

/* BKParking - Global Base Styles */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --primary: #003d9b;
  --primary-hover: #0052cc;
  --primary-light: #eff6ff;
  --secondary: #525f73;
  --sidebar-width: 250px;
  --success: #16a34a;
  --danger: #ba1a1a;
  --warning: #d97706;
  --surface: #f7f9fc;
  --surface-card: #ffffff;
  --border: #e2e8f0;
  --text-primary: #191c1e;
  --text-secondary: #64748b;
  --text-muted: #94a3b8;
  --topnav-height: 64px;
}

html, body, #root {
  height: 100%;
  overflow: hidden;
}

body {
  font-family: 'Inter', sans-serif;
  background-color: var(--surface);
  color: var(--text-primary);
  -webkit-font-smoothing: antialiased;
}

h1,h2,h3,h4,h5,h6 {
  font-family: 'Space Grotesk', sans-serif;
}

/* ============================
   SCROLLBAR
============================*/
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: #f1f5f9; }
::-webkit-scrollbar-thumb { background: #c3c6d6; border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: #737685; }

.no-scrollbar::-webkit-scrollbar { display: none; }
.no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

/* ============================
   PAGE TRANSITION
============================*/
.page-enter {
  animation: fadeInPage 0.25s ease forwards;
}
@keyframes fadeInPage {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ============================
   SIDEBAR (kept for nav-item styles)
============================*/



.nav-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 11px 16px;
  cursor: pointer;
  border-radius: 8px;
  margin: 2px 8px;
  transition: background 0.2s, color 0.2s, transform 0.15s;
  color: #475569;
  font-size: 13.5px;
  font-weight: 500;
  border: none;
  background: none;
  width: calc(100% - 16px);
  text-align: left;
  border-right: 3px solid transparent;
}

.nav-item:hover {
  background: #f1f5f9;
  color: var(--primary);
  transform: translateX(2px);
}

.nav-item.active {
  background: rgba(0,82,204,0.08);
  color: var(--primary) !important;
  border-right-color: var(--primary);
  font-weight: 700;
}

.nav-item .material-symbols-outlined {
  font-size: 20px;
  flex-shrink: 0;
}

.nav-section-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: var(--text-muted);
  text-transform: uppercase;
  padding: 16px 24px 8px;
}

/* ============================
   MAIN CONTENT (layout is flex, no margin needed)
============================*/

/* ============================
   TOP NAV
============================*/
.topnav {
  position: sticky;
  top: 0;
  z-index: 40;
  background: rgba(248,250,252,0.9);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
  padding: 12px 32px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  min-height: var(--topnav-height);
}

.topnav-search {
  position: relative;
  max-width: 380px;
  width: 100%;
}

.topnav-search input {
  width: 100%;
  padding: 9px 12px 9px 36px;
  background: #eceef1;
  border: none;
  border-radius: 10px;
  font-size: 13px;
  outline: none;
  font-family: 'Inter', sans-serif;
  transition: box-shadow 0.2s;
}

.topnav-search input:focus {
  box-shadow: 0 0 0 3px rgba(0,61,155,0.12);
}

.topnav-search .search-icon {
  position: absolute;
  left: 10px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 18px;
  color: #94a3b8;
}

/* ============================
   CARDS
============================*/
.card {
  background: var(--surface-card);
  border-radius: 16px;
  border: 1px solid var(--border);
  box-shadow: 0 2px 12px -2px rgba(0,61,155,0.06);
}

.card-hover {
  transition: box-shadow 0.2s, transform 0.2s;
}

.card-hover:hover {
  box-shadow: 0 8px 24px -4px rgba(0,61,155,0.12);
  transform: translateY(-1px);
}

/* ============================
   BADGES
============================*/
.badge {
  display: inline-flex;
  align-items: center;
  padding: 2px 10px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.02em;
}
.badge-green  { background:#dcfce7; color:#166534; }
.badge-red    { background:#fee2e2; color:#991b1b; }
.badge-amber  { background:#fef3c7; color:#92400e; }
.badge-blue   { background:#dbeafe; color:#1e40af; }
.badge-purple { background:#ede9fe; color:#5b21b6; }
.badge-orange { background:#ffedd5; color:#9a3412; }

/* ============================
   BUTTONS
============================*/
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 10px 20px;
  border-radius: 10px;
  font-weight: 700;
  font-size: 13px;
  cursor: pointer;
  border: none;
  transition: all 0.2s;
  font-family: 'Space Grotesk', sans-serif;
}

.btn-primary {
  background: var(--primary);
  color: #fff;
  box-shadow: 0 4px 16px rgba(0,61,155,0.2);
}
.btn-primary:hover { background: var(--primary-hover); }

.btn-ghost {
  background: #f1f5f9;
  color: #475569;
  border: 1px solid var(--border);
}
.btn-ghost:hover { background: #e2e8f0; }

.btn-danger {
  background: #ffdad6;
  color: #ba1a1a;
}
.btn-danger:hover { background: #ffb4ab; }

/* ============================
   TABLES
============================*/
.table-wrap {
  overflow-x: auto;
}
table { width: 100%; border-collapse: collapse; font-size: 13px; }
thead tr { background: #f8fafc; }
th {
  padding: 13px 20px;
  text-align: left;
  font-size: 10.5px;
  font-weight: 700;
  color: #64748b;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  white-space: nowrap;
}
td { padding: 14px 20px; }
tbody tr { border-top: 1px solid #f1f5f9; transition: background 0.15s; }
tbody tr:hover { background: rgba(0,61,155,0.02); }

/* ============================
   STATUS PULSE
============================*/
.pulse { animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
@keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:.4;} }

/* ============================
   GLASS
============================*/
.glass {
  background: rgba(255,255,255,0.8);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

/* ============================
   PARKING GRID
============================*/
.parking-grid {
  display: grid;
  grid-template-columns: repeat(10, minmax(0, 1fr));
  gap: 8px;
}

/* ============================
   MODAL
============================*/
.modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
  background: rgba(0,0,0,0.35);
  backdrop-filter: blur(4px);
  animation: fadeInPage 0.2s ease;
}

.modal-box {
  background: #fff;
  border-radius: 20px;
  box-shadow: 0 24px 64px rgba(0,0,0,0.18);
  width: 100%;
  max-width: 560px;
  animation: fadeInPage 0.2s ease;
}

/* ============================
   MATERIAL SYMBOLS
============================*/
.material-symbols-outlined {
  font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
}

/* ============================
   USER PORTAL (Mobile-friendly)
============================*/
.user-header {
  background: linear-gradient(135deg, #003d9b 0%, #0052cc 60%, #1a6bff 100%);
  padding: 20px 24px;
  color: #fff;
}

.user-bottom-nav {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  border-top: 1px solid var(--border);
  display: flex;
  z-index: 50;
  padding-bottom: env(safe-area-inset-bottom, 0px);
}

.user-nav-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  padding: 10px;
  border: none;
  background: none;
  cursor: pointer;
  color: #94a3b8;
  font-size: 10px;
  font-weight: 600;
  font-family: 'Inter', sans-serif;
  transition: color 0.2s;
}

.user-nav-btn.active {
  color: var(--primary);
}

.user-nav-btn .material-symbols-outlined {
  font-size: 22px;
}

.user-content {
  max-width: 480px;
  margin: 0 auto;
  padding: 20px 20px 90px;
}

/* ============================
   GRADIENTS
============================*/
.bkpay-gradient {
  background: linear-gradient(135deg, #003d9b 0%, #0052cc 50%, #1a6bff 100%);
}

/* ============================
   FORM INPUTS
============================*/
.form-input {
  width: 100%;
  padding: 12px 16px;
  background: #f8fafc;
  border: 1.5px solid var(--border);
  border-radius: 12px;
  font-size: 14px;
  outline: none;
  font-family: 'Inter', sans-serif;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.form-input:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(0,61,155,0.1);
}

.form-label {
  display: block;
  font-size: 12.5px;
  font-weight: 600;
  color: #334155;
  margin-bottom: 6px;
}

/* ============================
   LOADING
============================*/
.loading-spinner {
  width: 36px; height: 36px;
  border: 4px solid #e2e8f0;
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ============================
   RESPONSIVE
============================*/
@media (max-width: 768px) {
  .sidebar { transform: translateX(-100%); }
  .sidebar.open { transform: translateX(0); }
  .main-content { margin-left: 0; }
}
