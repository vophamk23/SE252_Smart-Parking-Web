# Copy file này thành .env và điền giá trị thực vào
# KHÔNG commit file .env lên Git

# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# CORS - Origin của Frontend
# Mặc định chỉ cho localhost:3000
CLIENT_URL=http://localhost:3000

# Muốn cho phép thêm host khác thì thêm vào đây (cách nhau bằng dấu phẩy)
# Ví dụ truy cập từ máy khác trong LAN:
# ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.5:3000
# Ví dụ deploy production:
# ALLOWED_ORIGINS=http://localhost:3000,https://bkparking.hcmut.edu.vn
ALLOWED_ORIGINS=http://localhost:3000
